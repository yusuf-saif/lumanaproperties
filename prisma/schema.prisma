datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPER_ADMIN
  PROPERTY_MANAGER
  STAFF
  VIEWER
}

enum RoomType {
  STUDIO
  ONE_BEDROOM
  TWO_BEDROOM
  THREE_BEDROOM
  PENTHOUSE
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
  OUT_OF_SERVICE
}

enum OccupancyStatus {
  OCCUPIED
  VACANT
  CHECKOUT
  NO_SHOW
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MaintenanceStatus {
  REPORTED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum MaintenanceCategory {
  ELECTRICAL
  PLUMBING
  HVAC
  FURNITURE
  APPLIANCE
  OTHER
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  POS
  ONLINE
}

enum IncomeSource {
  ACCOMMODATION
  MINIBAR
  LAUNDRY
  SERVICE_CHARGE
  OTHER
}

model User {
  id                   String             @id @default(cuid())
  name                 String
  email                String             @unique
  password             String
  role                 Role               @default(STAFF)
  active               Boolean            @default(true)
  phone                String?
  lastLoginAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  propertyUsers        PropertyUser[]
  reports              DailyReport[]
  maintenanceRaised    MaintenanceIssue[] @relation("RaisedBy")
  maintenanceResolved  MaintenanceIssue[] @relation("ResolvedBy")
  maintenanceAssigned  MaintenanceIssue[] @relation("AssignedTo")
  incomeRecords        IncomeRecord[]
}

model Property {
  id            String           @id @default(cuid())
  name          String
  address       String
  active        Boolean          @default(true)
  createdAt     DateTime         @default(now())
  areas         Area[]
  propertyUsers PropertyUser[]
  reports       DailyReport[]
  maintenance   MaintenanceIssue[]
  incomeRecords IncomeRecord[]
}

model PropertyUser {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  user       User     @relation(fields: [userId], references: [id])
  property   Property @relation(fields: [propertyId], references: [id])

  @@unique([userId, propertyId])
}

model Area {
  id         String   @id @default(cuid())
  name       String
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
  active     Boolean  @default(true)
  rooms      Room[]
}

model Room {
  id              String           @id @default(cuid())
  name            String
  type            RoomType
  dailyRate       Float
  status          RoomStatus       @default(AVAILABLE)
  amenities       Json?
  areaId          String
  area            Area             @relation(fields: [areaId], references: [id])
  active          Boolean          @default(true)
  statusUpdatedAt DateTime         @default(now())
  reports         DailyReport[]
  maintenance     MaintenanceIssue[]
  incomeRecords   IncomeRecord[]
}

model DailyReport {
  id              String          @id @default(cuid())
  reportDate      DateTime
  propertyId      String
  roomId          String
  occupancyStatus OccupancyStatus
  guestName       String?
  guestCount      Int             @default(1)
  notes           String?
  submittedById   String
  createdAt       DateTime        @default(now())
  property        Property        @relation(fields: [propertyId], references: [id])
  room            Room            @relation(fields: [roomId], references: [id])
  submittedBy     User            @relation(fields: [submittedById], references: [id])

  @@unique([roomId, reportDate])
}

model MaintenanceIssue {
  id              String              @id @default(cuid())
  title           String
  description     String
  priority        MaintenancePriority @default(MEDIUM)
  status          MaintenanceStatus   @default(REPORTED)
  category        MaintenanceCategory @default(OTHER)
  photos          String[]
  propertyId      String
  roomId          String
  raisedById      String
  assignedToId    String?
  resolvedById    String?
  resolvedAt      DateTime?
  resolutionNotes String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  property        Property            @relation(fields: [propertyId], references: [id])
  room            Room                @relation(fields: [roomId], references: [id])
  raisedBy        User                @relation("RaisedBy", fields: [raisedById], references: [id])
  assignedTo      User?               @relation("AssignedTo", fields: [assignedToId], references: [id])
  resolvedBy      User?               @relation("ResolvedBy", fields: [resolvedById], references: [id])
}

model InviteToken {
  id        String   @id @default(cuid())
  email     String
  role      Role
  token     String   @unique
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model IncomeRecord {
  id            String        @id @default(cuid())
  roomId        String
  propertyId    String
  recordedById  String
  amount        Float
  source        IncomeSource  @default(ACCOMMODATION)
  paymentMethod PaymentMethod
  recordDate    DateTime
  guestName     String?
  reference     String?
  verified      Boolean       @default(false)
  notes         String?
  createdAt     DateTime      @default(now())
  room          Room          @relation(fields: [roomId], references: [id])
  property      Property      @relation(fields: [propertyId], references: [id])
  recordedBy    User          @relation(fields: [recordedById], references: [id])
}
